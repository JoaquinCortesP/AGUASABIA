{
  "info": {
    "_postman_id": "8f5400b0-ec88-4aa5-97d2-aguasabia-ea3",
    "name": "AguaSabia Backend - Estado de Avance 3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para probar el backend de AguaSabia como plataforma de consulta territorial por poligono."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "consultaId", "value": "" }
  ],
  "item": [
    {
      "name": "CP-001 API raiz",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      }
    },
    {
      "name": "CP-003 Login admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.access_token) pm.collectionVariables.set('adminToken', json.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "username", "value": "admin@aguasabia.cl", "type": "text" },
            { "key": "password", "value": "admin123", "type": "text" }
          ]
        },
        "url": "{{baseUrl}}/api/v1/login/access-token"
      }
    },
    {
      "name": "CP-004 Admin me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/admin/me"
      }
    },
    {
      "name": "CP-005 Registrar usuario",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Usuario Prueba\",\n  \"email\": \"usuario.prueba@aguasabia.cl\",\n  \"password\": \"usuario123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/usuarios/register"
      }
    },
    {
      "name": "CP-006 Login usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.access_token) pm.collectionVariables.set('userToken', json.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuario.prueba@aguasabia.cl\",\n  \"password\": \"usuario123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/usuarios/login"
      }
    },
    {
