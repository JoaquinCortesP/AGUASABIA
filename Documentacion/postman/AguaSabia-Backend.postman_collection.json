{
  "info": {
    "_postman_id": "8f5400b0-ec88-4aa5-97d2-aguasabia-backend",
    "name": "AguaSabia Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion base para probar autenticacion de admin, catalogos, agricultores, parcelas y consumo de Open-Meteo desde el backend."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "municipioId",
      "value": "1"
    },
    {
      "key": "agricultorId",
      "value": "1"
    },
    {
      "key": "parcelaId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Admin - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin Postman\",\n  \"email\": \"admin.postman@example.com\",\n  \"password\": \"admin12345\",\n  \"municipio_id\": {{municipioId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login - Access Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.access_token) {",
              "  pm.collectionVariables.set('token', response.access_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "admin@aguasabia.cl",
              "type": "text"
            },
            {
              "key": "password",
              "value": "admin123",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/login/access-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "login",
            "access-token"
          ]
        }
      }
    },
    {
      "name": "Admin - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "me"
          ]
        }
      }
    },
    {
      "name": "Municipios - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/municipios/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "municipios",
            "me"
          ]
        }
      }
    },
    {
      "name": "Catalogos - Regiones",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalogos/regiones",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "catalogos",
            "regiones"
          ]
        }
      }
    },
    {
      "name": "Catalogos - Comunas por Region",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalogos/comunas?region_id=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "catalogos",
            "comunas"
          ],
          "query": [
            {
              "key": "region_id",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "Clima - Diario por Punto",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/clima/diario?latitud=-33.4489&longitud=-70.6693",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "clima",
            "diario"
          ],
          "query": [
            {
              "key": "latitud",
              "value": "-33.4489"
            },
            {
              "key": "longitud",
              "value": "-70.6693"
            }
          ]
        }
      }
    },
    {
      "name": "Clima - Diario por Poligono",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"poligono_vertices\": [\n    { \"latitud\": -33.4480, \"longitud\": -70.6700 },\n    { \"latitud\": -33.4480, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6700 }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/clima/diario/poligono",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "clima",
            "diario",
            "poligono"
          ]
        }
      }
    },
    {
      "name": "Agricultores - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.id) {",
              "  pm.collectionVariables.set('agricultorId', response.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Agricultor Postman\",\n  \"email\": \"agricultor.postman@example.com\",\n  \"password\": \"agri12345\",\n  \"is_active\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/agricultores/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "agricultores",
            ""
          ]
        }
      }
    },
    {
      "name": "Agricultores - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/agricultores/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "agricultores",
            ""
          ]
        }
      }
    },
    {
      "name": "Parcelas - Create con Poligono",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.id) {",
              "  pm.collectionVariables.set('parcelaId', response.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Parcela Demo\",\n  \"agricultor_id\": {{agricultorId}},\n  \"comuna_id\": 1,\n  \"superficie\": 2.5,\n  \"tipo_cultivo\": \"Tomate\",\n  \"poligono_vertices\": [\n    { \"latitud\": -33.4480, \"longitud\": -70.6700 },\n    { \"latitud\": -33.4480, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6700 }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/parcelas/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parcelas",
            ""
          ]
        }
      }
    },
    {
      "name": "Parcelas - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/parcelas/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parcelas",
            ""
          ]
        }
      }
    },
    {
      "name": "Parcelas - Detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/parcelas/{{parcelaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
