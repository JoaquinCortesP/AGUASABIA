            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.consulta_id) pm.collectionVariables.set('consultaId', json.consulta_id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Consulta demo Santiago\",\n  \"poligono\": [\n    { \"latitud\": -33.4480, \"longitud\": -70.6700 },\n    { \"latitud\": -33.4480, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6680 },\n    { \"latitud\": -33.4500, \"longitud\": -70.6700 }\n  ],\n  \"modo\": \"resumen\",\n  \"guardar\": true,\n  \"modulos\": [\"agua\", \"clima\", \"territorio\", \"vegetacion\", \"riesgos\"]\n}"
